{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "ServerFacadeHttpResponse is a static HTTP response returned by a facade route.",
  "properties": {
    "body": {
      "description": "Response body. Marshalled as JSON and sent as the response.",
      "title": "Value"
    },
    "headers": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Response headers.",
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "status": {
      "anyOf": [
        {
          "maximum": 599,
          "minimum": 100,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0,
      "description": "HTTP status code."
    }
  },
  "title": "Server Facade Http Response",
  "type": "object"
}